<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>One row per Budget Line in the reconciliation result set. Stores the matched Counterpoint actuals aggregate, the dollar and unit variance, and the reconciliation status for reporting. Unmatched Actuals (orders with no corresponding Budget Line) are also stored here.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Reconciliation Line</label>
    <nameField>
        <displayFormat>REC-{000000}</displayFormat>
        <label>Reconciliation Line</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Reconciliation Lines</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>

    <listViews>
        <fullName>All_Reconciliation_Lines</fullName>
        <columns>NAME</columns>
        <columns>Reconciliation_Status__c</columns>
        <columns>Opportunity__c</columns>
        <columns>Channel__c</columns>
        <columns>Vehicle__c</columns>
        <columns>Month__c</columns>
        <columns>Fiscal_Year__c</columns>
        <columns>Planned_Amount__c</columns>
        <columns>Actual_Amount__c</columns>
        <columns>Variance_Amount__c</columns>
        <filterScope>Everything</filterScope>
        <label>All Reconciliation Lines</label>
    </listViews>
</CustomObject>
