<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Weighted_Amount__c</fullName>
    <label>Weighted Amount</label>
    <type>Currency</type>
    <precision>18</precision>
    <scale>2</scale>
    <required>false</required>
    <formula>NULLVALUE(Amount__c, 0) * NULLVALUE(Weight_Pct__c, 0) / 100</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <description>Amount × Weight%. Use this on weighted-forecast reports.</description>
</CustomField>
