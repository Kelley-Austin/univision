<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Canonical actual revenue record for one Account+Category+Revenue_Type+Year+Month grain. Populated by the ingestion pipeline (IngestService + transformers) via External_Id__c upsert. Used by accountBudgetGrid to compute Actual vs Budget variance.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Actual Revenue</label>
    <nameField>
        <displayFormat>ACT-{0000000}</displayFormat>
        <label>Actual Revenue Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Actual Revenues</pluralLabel>
    <searchLayouts/>
    <sharingModel>Private</sharingModel>
</CustomObject>
