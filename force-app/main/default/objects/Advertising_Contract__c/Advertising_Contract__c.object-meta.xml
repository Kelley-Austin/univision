        <displayFormat>CNT-{000000}</displayFormat>
        <label>Contract Number</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Advertising Contracts</pluralLabel>
    <searchLayouts/>
