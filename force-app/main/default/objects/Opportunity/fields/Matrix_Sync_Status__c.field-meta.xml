<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Matrix_Sync_Status__c</fullName>
    <description>Tracks the current state of the outbound sync to Matrix. Failed records can be retried by changing Status back to Active or triggering a resync flow.</description>
    <label>Matrix Sync Status</label>
    <required>false</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Not Synced</fullName>
                <default>true</default>
                <label>Not Synced</label>
            </value>
            <value>
                <fullName>Pending</fullName>
                <default>false</default>
                <label>Pending</label>
            </value>
            <value>
                <fullName>Synced</fullName>
                <default>false</default>
                <label>Synced</label>
            </value>
            <value>
                <fullName>Failed</fullName>
                <default>false</default>
                <label>Failed</label>
            </value>
            <value>
                <fullName>Conflict</fullName>
                <default>false</default>
                <label>Conflict</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
