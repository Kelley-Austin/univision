<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Audit log for Matrix inventory sync runs. One record is written by MatrixInventorySyncQueueable after every sync attempt (scheduled or manual).</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>false</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Matrix Sync Log</label>
    <nameField>
        <displayFormat>SL-{0000000}</displayFormat>
        <label>Sync Log Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Matrix Sync Logs</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>
