<?xml version="1.0" encoding="UTF-8"?>
<FlexiPage xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Lightning Record Page for Budget Line. Surfaces spot details, copy fields, traffic status, and planned vs. actual amounts. The Traffic Copy Entry quick action is accessible from the action bar in the highlights panel.</description>
    <masterLabel>Budget Line Record Page</masterLabel>
    <sobjectType>Budget_Line__c</sobjectType>
    <type>RecordPage</type>

    <!-- Header: key budget line fields + action bar (Traffic Copy Entry quick action appears here) -->
    <flexiPageRegions>
        <componentInstances>
            <componentInstanceProperties>
                <name>variant</name>
                <value>base</value>
            </componentInstanceProperties>
            <componentName>force:highlightsPanel</componentName>
        </componentInstances>
        <mode>AppDefault</mode>
        <name>header</name>
        <type>Region</type>
    </flexiPageRegions>

    <!-- Main body -->
    <flexiPageRegions>
        <!-- Standard field detail (spot fields, copy details, traffic status, amounts) -->
        <componentInstances>
            <componentName>force:recordDetail</componentName>
        </componentInstances>

        <!-- All related lists (files, activities, etc.) -->
        <componentInstances>
            <componentName>force:relatedListContainer</componentName>
        </componentInstances>

        <mode>AppDefault</mode>
        <name>main</name>
        <type>Region</type>
    </flexiPageRegions>

</FlexiPage>
