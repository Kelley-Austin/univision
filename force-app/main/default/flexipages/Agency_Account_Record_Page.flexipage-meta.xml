<?xml version="1.0" encoding="UTF-8"?>
<FlexiPage xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Lightning Record Page for Agency accounts. Includes a Managed Advertisers related list showing all Direct Buy and Advertiser accounts whose Primary_Agency__c points to this agency.</description>
    <masterLabel>Agency Account Record Page</masterLabel>
    <sobjectType>Account</sobjectType>
    <type>RecordPage</type>

    <!-- Header: highlights panel with key fields and action buttons -->
    <flexiPageRegions>
        <componentInstances>
            <componentInstanceProperties>
                <name>variant</name>
                <value>base</value>
            </componentInstanceProperties>
            <componentName>force:highlightsPanel</componentName>
        </componentInstances>
        <mode>AppDefault</mode>
        <name>header</name>
        <type>Region</type>
    </flexiPageRegions>

    <!-- Main body: record detail, Managed Advertisers list, then all other related lists -->
    <flexiPageRegions>
        <componentInstances>
            <componentName>force:recordDetail</componentName>
        </componentInstances>
        <componentInstances>
            <componentInstanceProperties>
                <name>heading</name>
                <value>Managed Advertisers</value>
            </componentInstanceProperties>
            <componentInstanceProperties>
                <name>relatedList</name>
                <value>Managed_Advertisers</value>
            </componentInstanceProperties>
            <componentName>force:relatedListSingleContainer</componentName>
        </componentInstances>
        <componentInstances>
            <componentName>force:relatedListContainer</componentName>
        </componentInstances>
        <mode>AppDefault</mode>
        <name>main</name>
        <type>Region</type>
    </flexiPageRegions>

</FlexiPage>
