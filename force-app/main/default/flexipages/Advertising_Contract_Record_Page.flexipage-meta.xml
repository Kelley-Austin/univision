<?xml version="1.0" encoding="UTF-8"?>
<FlexiPage xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Lightning Record Page for Advertising Contract. Surfaces contract terms, traffic status, e-signature fields, and cancellation/make-good details. The Make-Good / Cancel quick action is accessible from the action bar in the highlights panel.</description>
    <masterLabel>Advertising Contract Record Page</masterLabel>
    <sobjectType>Advertising_Contract__c</sobjectType>
    <type>RecordPage</type>

    <!-- Header: key contract fields + action bar (Make-Good / Cancel quick action appears here) -->
    <flexiPageRegions>
        <componentInstances>
            <componentInstanceProperties>
                <name>variant</name>
                <value>base</value>
            </componentInstanceProperties>
            <componentName>force:highlightsPanel</componentName>
        </componentInstances>
        <mode>AppDefault</mode>
        <name>header</name>
        <type>Region</type>
    </flexiPageRegions>

    <!-- Main body -->
    <flexiPageRegions>
        <!-- Standard field detail (contract terms, traffic, e-sig, cancellation fields) -->
        <componentInstances>
            <componentName>force:recordDetail</componentName>
        </componentInstances>

        <!-- All related lists (files, activities, chatter, etc.) -->
        <componentInstances>
            <componentName>force:relatedListContainer</componentName>
        </componentInstances>

        <mode>AppDefault</mode>
        <name>main</name>
        <type>Region</type>
    </flexiPageRegions>

</FlexiPage>
