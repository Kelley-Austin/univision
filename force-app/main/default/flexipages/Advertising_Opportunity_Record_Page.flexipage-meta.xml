<?xml version="1.0" encoding="UTF-8"?>
<FlexiPage xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Lightning Record Page for Advertising Opportunity. Surfaces key fields, the AE projection grid, Budget Lines, and Contracts without leaving the record. Quick action Import Counterpoint Data is accessible from the action bar in the highlights panel.</description>
    <masterLabel>Advertising Opportunity Record Page</masterLabel>
    <sobjectType>Advertising_Opportunity__c</sobjectType>
    <type>RecordPage</type>

    <!-- Header: key fields + action bar (Import Counterpoint Data quick action appears here) -->
    <flexiPageRegions>
        <componentInstances>
            <componentInstanceProperties>
                <name>variant</name>
                <value>base</value>
            </componentInstanceProperties>
            <componentName>force:highlightsPanel</componentName>
        </componentInstances>
        <mode>AppDefault</mode>
        <name>header</name>
        <type>Region</type>
    </flexiPageRegions>

    <!-- Main body -->
    <flexiPageRegions>
        <!-- Standard field detail -->
        <componentInstances>
            <componentName>force:recordDetail</componentName>
        </componentInstances>

        <!-- AE Projection Grid: enter/edit monthly projections inline -->
        <componentInstances>
            <componentName>c:aeProjectionGrid</componentName>
        </componentInstances>

        <!-- Budget Lines: view and navigate lines without leaving the record -->
        <componentInstances>
            <componentInstanceProperties>
                <name>heading</name>
                <value>Budget Lines</value>
            </componentInstanceProperties>
            <componentInstanceProperties>
                <name>relatedList</name>
                <value>Budget_Lines</value>
            </componentInstanceProperties>
            <componentName>force:relatedListSingleContainer</componentName>
        </componentInstances>

        <!-- Advertising Contracts: contracts promoted from this opportunity -->
        <componentInstances>
            <componentInstanceProperties>
                <name>heading</name>
                <value>Advertising Contracts</value>
            </componentInstanceProperties>
            <componentInstanceProperties>
                <name>relatedList</name>
                <value>Advertising_Contracts</value>
            </componentInstanceProperties>
            <componentName>force:relatedListSingleContainer</componentName>
        </componentInstances>

        <!-- All remaining related lists (activities, files, etc.) -->
        <componentInstances>
            <componentName>force:relatedListContainer</componentName>
        </componentInstances>

        <mode>AppDefault</mode>
        <name>main</name>
        <type>Region</type>
    </flexiPageRegions>

</FlexiPage>
