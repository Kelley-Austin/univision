<?xml version="1.0" encoding="UTF-8"?>
<FlexiPage xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Lightning Record Page for Pitch Project. Shows pacing against the project goal, participating outlets, and linked Actual Revenues. The New Pitch Project quick action is accessible from the action bar in the highlights panel.</description>
    <masterLabel>Pitch Project Record Page</masterLabel>
    <sobjectType>Pitch_Project__c</sobjectType>
    <type>RecordPage</type>

    <!-- Header: pitch project key fields + action bar (New Pitch Project quick action appears here) -->
    <flexiPageRegions>
        <componentInstances>
            <componentInstanceProperties>
                <name>variant</name>
                <value>base</value>
            </componentInstanceProperties>
            <componentName>force:highlightsPanel</componentName>
        </componentInstances>
        <mode>Replace</mode>
        <name>header</name>
        <type>Region</type>
    </flexiPageRegions>

    <!-- Main body -->
    <flexiPageRegions>
        <!-- Standard field detail -->
        <componentInstances>
            <componentName>force:recordDetail</componentName>
        </componentInstances>

        <!-- Pacing component: booked/pending/forecast vs. goal with progress bar -->
        <componentInstances>
            <componentName>c:pitchProjectPacing</componentName>
        </componentInstances>

        <!-- All related lists (Pitch Project Outlets junction, files, etc.) -->
        <componentInstances>
            <componentName>force:relatedListContainer</componentName>
        </componentInstances>

        <mode>Replace</mode>
        <name>main</name>
        <type>Region</type>
    </flexiPageRegions>

</FlexiPage>
