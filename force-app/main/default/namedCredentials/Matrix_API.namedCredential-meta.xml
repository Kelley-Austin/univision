<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Matrix API</label>
    <!-- SETUP REQUIRED: Replace the endpoint below with the real Matrix base URL.
         Then open Setup → Named Credentials → Matrix API and enter the username
         and password for the Matrix service account under "Authentication". -->
    <endpoint>https://matrix.example.com/api/v1</endpoint>
    <principalType>NamedUser</principalType>
    <protocol>Password</protocol>
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
</NamedCredential>
