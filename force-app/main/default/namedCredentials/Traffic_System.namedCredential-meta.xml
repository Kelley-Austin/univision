<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <!-- DEPLOYMENT NOTE: Update the <url> value to the actual traffic system endpoint before deploying to Production.
         Set the API key header value in Setup > Named Credentials after deployment.
         The Apex callout uses endpoint: callout:Traffic_System/orders -->
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>true</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <label>Traffic System</label>
    <principalType>Anonymous</principalType>
    <protocol>NoAuthentication</protocol>
    <type>Legacy</type>
    <url>https://trafficapi.example.com</url>
</NamedCredential>
