<?xml version="1.0" encoding="UTF-8"?>
<Dashboard xmlns="http://soap.sforce.com/2006/04/metadata">
    <backgroundEndColor>#F3F3F3</backgroundEndColor>
    <backgroundFadeDirection>Diagonal</backgroundFadeDirection>
    <backgroundStartColor>#FFFFFF</backgroundStartColor>

    <!-- Left column: pacing + rep productivity -->
    <components>
        <chartAxisRange>Auto</chartAxisRange>
        <column>Left</column>
        <componentType>Bar</componentType>
        <displayUnits>Auto</displayUnits>
        <drillEnabled>true</drillEnabled>
        <drillToDetailEnabled>true</drillToDetailEnabled>
        <enableHover>true</enableHover>
        <expandOtherItems>false</expandOtherItems>
        <header>Pacing</header>
        <legendPosition>Bottom</legendPosition>
        <maxValuesDisplayed>15</maxValuesDisplayed>
        <report>MediaCloud/Current_Month_Pacing</report>
        <showPercentage>false</showPercentage>
        <showTotal>true</showTotal>
        <showValues>true</showValues>
        <sortBy>RowLabelAscending</sortBy>
        <title>Current Month: Planned vs. Actual by Channel</title>
        <useReportChart>true</useReportChart>
    </components>
    <components>
        <chartAxisRange>Auto</chartAxisRange>
        <column>Left</column>
        <componentType>Bar</componentType>
        <displayUnits>Auto</displayUnits>
        <drillEnabled>true</drillEnabled>
        <drillToDetailEnabled>true</drillToDetailEnabled>
        <enableHover>true</enableHover>
        <expandOtherItems>false</expandOtherItems>
        <header>Rep Performance</header>
        <legendPosition>Bottom</legendPosition>
        <maxValuesDisplayed>10</maxValuesDisplayed>
        <report>MediaCloud/Rep_Productivity</report>
        <showPercentage>false</showPercentage>
        <showTotal>true</showTotal>
        <showValues>true</showValues>
        <sortBy>RowValueDescending</sortBy>
        <title>Rep Productivity — Fiscal Year to Date</title>
        <useReportChart>true</useReportChart>
    </components>

    <!-- Middle column: pipeline by market + 30/60/90 -->
    <components>
        <chartAxisRange>Auto</chartAxisRange>
        <column>Middle</column>
        <componentType>Bar</componentType>
        <displayUnits>Auto</displayUnits>
        <drillEnabled>true</drillEnabled>
        <drillToDetailEnabled>true</drillToDetailEnabled>
        <enableHover>true</enableHover>
        <expandOtherItems>false</expandOtherItems>
        <header>Pipeline</header>
        <legendPosition>Bottom</legendPosition>
        <maxValuesDisplayed>15</maxValuesDisplayed>
        <report>MediaCloud/Pipeline_by_Market</report>
        <showPercentage>false</showPercentage>
        <showTotal>true</showTotal>
        <showValues>true</showValues>
        <sortBy>RowValueDescending</sortBy>
        <title>Pipeline Budget by Market</title>
        <useReportChart>true</useReportChart>
    </components>
    <components>
        <chartAxisRange>Auto</chartAxisRange>
        <column>Middle</column>
        <componentType>Bar</componentType>
        <displayUnits>Auto</displayUnits>
        <drillEnabled>true</drillEnabled>
        <drillToDetailEnabled>true</drillToDetailEnabled>
        <enableHover>true</enableHover>
        <expandOtherItems>false</expandOtherItems>
        <header>Near-Term Pipeline</header>
        <legendPosition>Bottom</legendPosition>
        <maxValuesDisplayed>10</maxValuesDisplayed>
        <report>MediaCloud/Pipeline_30_60_90_Day</report>
        <showPercentage>false</showPercentage>
        <showTotal>true</showTotal>
        <showValues>true</showValues>
        <sortBy>RowLabelAscending</sortBy>
        <title>30/60/90-Day Pipeline by Status</title>
        <useReportChart>true</useReportChart>
    </components>

    <!-- Right column: deal aging -->
    <components>
        <chartAxisRange>Auto</chartAxisRange>
        <column>Right</column>
        <componentType>Bar</componentType>
        <displayUnits>Auto</displayUnits>
        <drillEnabled>true</drillEnabled>
        <drillToDetailEnabled>true</drillToDetailEnabled>
        <enableHover>true</enableHover>
        <expandOtherItems>false</expandOtherItems>
        <header>Deal Health</header>
        <legendPosition>Bottom</legendPosition>
        <maxValuesDisplayed>15</maxValuesDisplayed>
        <report>MediaCloud/Deal_Aging</report>
        <showPercentage>false</showPercentage>
        <showTotal>true</showTotal>
        <showValues>true</showValues>
        <sortBy>RowLabelAscending</sortBy>
        <title>Open Deals by Rep (Oldest First)</title>
        <useReportChart>true</useReportChart>
    </components>

    <dashboardType>LoggedInUser</dashboardType>
    <description>Sales manager dashboard: current-month pacing, 30/60/90-day pipeline, deal aging, and individual rep stats — all without leaving Salesforce.</description>
    <leftSize>Medium</leftSize>
    <middleSize>Medium</middleSize>
    <rightSize>Medium</rightSize>
    <textColor>#000000</textColor>
    <title>Sales Manager Dashboard</title>
    <titleColor>#000000</titleColor>
    <titleSize>12</titleSize>
</Dashboard>
