<?xml version="1.0" encoding="UTF-8"?>
<Dashboard xmlns="http://soap.sforce.com/2006/04/metadata">
    <backgroundEndColor>#FFFFFF</backgroundEndColor>
    <backgroundFadeDirection>Diagonal</backgroundFadeDirection>
    <backgroundStartColor>#FFFFFF</backgroundStartColor>
    <chartTheme>light</chartTheme>
    <colorPalette>Default</colorPalette>
    <description>Weekly analytics dashboard for the advertising team. Shows planned vs. actual revenue by market and by vehicle, plus month-by-month order pacing for the current fiscal year.</description>
    <isGridLayout>false</isGridLayout>

    <!-- Component 1: Revenue by Market bar chart -->
    <components>
        <chartAxisRange>Auto</chartAxisRange>
        <componentType>BarGrouped</componentType>
        <displayUnits>Auto</displayUnits>
        <footer>Current FY · Non-cancelled budget lines</footer>
        <header>Revenue by Market</header>
        <maxValuesDisplayed>20</maxValuesDisplayed>
        <report>Advertising_Analytics/Revenue_by_Market</report>
        <reportColumn1>Planned_Amount__c</reportColumn1>
        <reportColumn2>Actual_Amount__c</reportColumn2>
        <showPercentage>false</showPercentage>
        <showTotal>true</showTotal>
        <showValues>false</showValues>
        <sortBy>RowValueDescending</sortBy>
        <title>Planned vs. Actual Revenue by Market</title>
        <useReportChart>false</useReportChart>
    </components>

    <!-- Component 2: Revenue by Vehicle bar chart -->
    <components>
        <chartAxisRange>Auto</chartAxisRange>
        <componentType>BarGrouped</componentType>
        <displayUnits>Auto</displayUnits>
        <footer>Current FY · Non-cancelled budget lines</footer>
        <header>Revenue by Vehicle</header>
        <maxValuesDisplayed>20</maxValuesDisplayed>
        <report>Advertising_Analytics/Revenue_by_Vehicle</report>
        <reportColumn1>Planned_Amount__c</reportColumn1>
        <reportColumn2>Actual_Amount__c</reportColumn2>
        <showPercentage>false</showPercentage>
        <showTotal>true</showTotal>
        <showValues>false</showValues>
        <sortBy>RowValueDescending</sortBy>
        <title>Planned vs. Actual Revenue by Vehicle</title>
        <useReportChart>false</useReportChart>
    </components>

    <!-- Component 3: Order Pacing table (matrix report renders as table in dashboard) -->
    <components>
        <componentType>Table</componentType>
        <displayUnits>Auto</displayUnits>
        <footer>Current FY · Rows = Markets, Columns = Months</footer>
        <header>Order Pacing</header>
        <maxValuesDisplayed>25</maxValuesDisplayed>
        <report>Advertising_Analytics/Order_Pacing</report>
        <showTotal>true</showTotal>
        <sortBy>RowLabelAscending</sortBy>
        <title>Monthly Order Pacing by Market</title>
        <useReportChart>false</useReportChart>
    </components>

    <layout>
        <!-- Row 1: Revenue by Market | Revenue by Vehicle -->
        <layoutSections>
            <columnSize>MEDIUM</columnSize>
            <layoutColumns>
                <layoutItems>
                    <emptySpace>false</emptySpace>
                    <report>Advertising_Analytics/Revenue_by_Market</report>
                </layoutItems>
            </layoutColumns>
            <layoutColumns>
                <layoutItems>
                    <emptySpace>false</emptySpace>
                    <report>Advertising_Analytics/Revenue_by_Vehicle</report>
                </layoutItems>
            </layoutColumns>
            <style>HALVES</style>
        </layoutSections>
        <!-- Row 2: Order Pacing full-width -->
        <layoutSections>
            <columnSize>WIDE</columnSize>
            <layoutColumns>
                <layoutItems>
                    <emptySpace>false</emptySpace>
                    <report>Advertising_Analytics/Order_Pacing</report>
                </layoutItems>
            </layoutColumns>
            <style>ONECOL</style>
        </layoutSections>
    </layout>

    <name>Weekly Analytics Dashboard</name>
    <runningUser>clare.segrue@kelleyaustin.com</runningUser>
    <textColor>#000000</textColor>
    <title>Weekly Analytics Dashboard</title>
    <titleColor>#000000</titleColor>
    <titleSize>12</titleSize>
</Dashboard>
