<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Sales Representative — minimum permissions for the Create Direct Buy Advertiser, Create Agency Account, and Link Agency To Advertiser screen flows.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Matrix — Sales Representative</label>

    <!-- Field-level security: new fields required by the advertiser/agency flows -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Market__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Media_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Primary_Agency__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Account object: create, read, edit (no delete, no modify-all) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Read-only access to reference data needed for lookups in the flows -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Medium__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Office__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Outlet__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Record type visibility: Direct Buy Advertiser and Agency only -->
    <recordTypeVisibilities>
        <recordType>Account.Agency</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <recordTypeVisibilities>
        <recordType>Account.Direct_Buy</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>

    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>
</PermissionSet>
